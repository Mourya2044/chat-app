# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatapp
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Optional: AI Troll Detection (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_DETECTION_MODEL=llama-3.1-8b-instant

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
